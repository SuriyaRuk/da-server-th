# da-server configuration — AWS Asia Pacific (Thailand) zone
# Copy to .env and fill in your credentials. All vars use the OP_ALTDA_SERVER_ prefix.

# --- server ---
OP_ALTDA_SERVER_ADDR=0.0.0.0
OP_ALTDA_SERVER_PORT=3100

# --- S3 storage (Thailand zone) ---
# ap-southeast-7 = AWS Asia Pacific (Thailand). The region is selected by the
# endpoint; there is no separate region flag.
OP_ALTDA_SERVER_S3_ENDPOINT=s3.ap-southeast-7.amazonaws.com
OP_ALTDA_SERVER_S3_BUCKET=my-altda-bucket-th
OP_ALTDA_SERVER_S3_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
OP_ALTDA_SERVER_S3_ACCESS_KEY_SECRET=YOUR_SECRET_ACCESS_KEY

# Note: the bucket must already exist in ap-southeast-7 and the credentials must
# have s3:GetObject / s3:PutObject on it. The client connects over TLS (Secure=true).
